# Variables de entorno del microservicio ARCA
# Copiá este archivo como .env y completá los valores.
# En Railway/Render se cargan desde el panel (Variables), no se sube el .env.

# URL de tu proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://jftuhqhwptnnheilmine.supabase.co

# Clave anónima pública (Settings → API → anon public)
SUPABASE_ANON_KEY=tu_anon_key

# Clave service_role SECRETA (Settings → API → service_role)
# ⚠ NUNCA va en el frontend. Solo acá, en el servidor.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Puerto (Railway lo setea solo; en local podés dejar 8080)
PORT=8080
